NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

MONGODB_URI=mongodb://localhost:27017/sitework

JWT_SECRET=change_me_to_a_very_long_random_string_minimum_64_chars
JWT_EXPIRES_IN=30d

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

FCM_PROJECT_ID=your_firebase_project_id
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

TEMP_UPLOAD_DIR=./uploads/temp
PROOF_PHOTO_MAX_SIZE_KB=400
PROOF_PHOTO_AUTO_DELETE_DAYS=7

TERMS_VERSION=v1.0
PRIVACY_VERSION=v1.0

ADMIN_EMAILS=admin@yourdomain.com
FRONTEND_URL=http://localhost:5173
