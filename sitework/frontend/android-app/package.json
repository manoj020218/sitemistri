    "react":               "^18.3.1",
    "react-dom":           "^18.3.1",
    "react-router-dom":    "^6.23.1",
    "axios":               "^1.7.2",
    "firebase":            "^10.12.1",
    "leaflet":             "^1.9.4",
    "react-leaflet":       "^4.2.1"
  },
  "devDependencies": {
    "@capacitor/cli":       "^8.0.0",
